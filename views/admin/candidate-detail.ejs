я╗┐<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .resume-preview-modal .modal-dialog { max-width: 860px; }
    .resume-iframe { width: 100%; height: 78vh; border: none; border-radius: 4px; background: #f5f5f5; }
    .resume-card {
      border: 2px dashed var(--gold);
      border-radius: 10px;
      background: var(--gold-light);
      padding: 16px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .resume-card .file-icon { font-size: 2.4rem; }
    .resume-card .file-icon.pdf  { color: #dc3545; }
    .resume-card .file-icon.docx { color: #0d6efd; }
  </style>
</head>
<body class="admin-page">
<div class="admin-wrapper">

  <!-- Sidebar -->
  <nav class="admin-sidebar d-flex flex-column">
    <div class="sidebar-brand">
      <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo" onerror="this.style.display='none'">
      <div>
        <div class="fw-bold text-gold">Patrika HR</div>
        <small class="text-white-50">Admin Panel</small>
      </div>
    </div>
    <hr class="border-secondary my-2">
    <ul class="nav flex-column px-2 flex-grow-1">
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/dashboard">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link active" href="/admin/candidates">
          <i class="bi bi-people-fill me-2"></i>Candidates
        </a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/positions">
          <i class="bi bi-briefcase-fill me-2"></i>Positions
        </a>
      </li>
      <% } %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/requisitions">
          <i class="bi bi-clipboard-check-fill me-2"></i>Requisitions
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/talent-analyst">
          <i class="bi bi-robot me-2"></i>Talent Analyst
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/smart-fit">
          <i class="bi bi-stars me-2"></i>Smart Fit Analyzer
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/resume-parser">
          <i class="bi bi-file-earmark-text me-2"></i>Resume Parser
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/apply" target="_blank">
          <i class="bi bi-file-earmark-person me-2"></i>Application Form
        </a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/users">
          <i class="bi bi-person-gear me-2"></i>User Management
        </a>
      </li>
      <% } %>
    </ul>
    <div class="px-2 pb-3">
      <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
      </a>
      <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">
        Logged in as <strong><%= adminName %></strong>
        <% if (typeof adminDepartment !== 'undefined' && adminDepartment) { %>
        <span class="badge bg-warning text-dark d-block mt-1"><%= adminDepartment %></span>
        <% } %>
      </p>
    </div>
  </nav>

  <!-- Main -->
  <main class="admin-main">
    <div class="admin-topbar d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center gap-3">
        <a href="javascript:void(0)" onclick="goBack()" class="btn btn-sm btn-outline-secondary" title="Back">
          <i class="bi bi-arrow-left"></i> Back
        </a>
        <div class="avatar-circle avatar-lg"><%= candidate.fullName.charAt(0).toUpperCase() %></div>
        <div>
          <h5 class="mb-0 fw-bold"><%= candidate.fullName %></h5>
          <small class="text-muted"><%= candidate.positionApplying %> &nbsp;┬╖&nbsp; Applied <%= new Date(candidate.submittedAt).toLocaleDateString('en-IN') %></small>
        </div>
      </div>
      <div class="d-flex gap-2">
        <% if (candidate.resumeFile) { %>
        <button class="btn btn-sm btn-gold" onclick="openPreview()">
          <i class="bi bi-eye-fill me-1"></i>Preview CV
        </button>
        <a href="/admin/candidate/<%= candidate.id %>/download" class="btn btn-sm btn-outline-success">
          <i class="bi bi-download me-1"></i>Download CV
        </a>
        <% } %>
        <button class="btn btn-sm btn-outline-purple" onclick="sendTest()" id="sendTestBtn" style="border-color:#6f42c1;color:#6f42c1;">
          <i class="bi bi-ui-checks me-1"></i>Send Test
        </button>
        <a href="/admin/candidate/<%= candidate.id %>/interview" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-clipboard-check me-1"></i>Interview Sheet
        </a>
        <a href="/admin/candidate/<%= candidate.id %>/timeline" class="btn btn-sm btn-outline-info">
          <i class="bi bi-clock-history me-1"></i>Activity History
        </a>
        <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#downloadBundleModal">
          <i class="bi bi-archive me-1"></i>Download Documents
        </button>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteCandidate('<%= candidate.id %>')">
          <i class="bi bi-trash me-1"></i>Delete
        </button>
      </div>
    </div>

    <div class="p-4">

      <!-- Flash Message -->
      <% if (flash) { %>
      <div class="alert alert-<%= flashType || 'success' %> alert-dismissible fade show py-2" role="alert">
        <i class="bi bi-check-circle me-1"></i> <%= flash %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>

      <div class="row g-4">

        <!-- ├втАЭтВм├втАЭтВм Left Column ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
        <div class="col-lg-7">

          <!-- Profile Card -->
          <div class="card shadow-sm mb-4">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-person me-2"></i>Candidate Profile</h6></div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-sm-6">
                  <label class="detail-label">Full Name</label>
                  <div class="detail-value fw-semibold"><%= candidate.fullName %></div>
                </div>
                <div class="col-sm-6">
                  <label class="detail-label">Email</label>
                  <div class="detail-value"><a href="mailto:<%= candidate.email %>"><%= candidate.email %></a></div>
                </div>
                <div class="col-sm-6">
                  <label class="detail-label">Contact Number</label>
                  <div class="detail-value"><a href="tel:+91<%= candidate.contactNumber %>">+91 <%= candidate.contactNumber %></a></div>
                </div>
                <div class="col-sm-6">
                  <label class="detail-label">Current Location</label>
                  <div class="detail-value"><%= candidate.currentLocation %></div>
                </div>
                <% if (candidate.linkedInProfile) { %>
                <div class="col-sm-12">
                  <label class="detail-label"><i class="bi bi-linkedin me-1" style="color:#0a66c2;"></i>LinkedIn Profile</label>
                  <div class="detail-value">
                    <a href="<%= candidate.linkedInProfile %>" target="_blank" rel="noopener">
                      <%= candidate.linkedInProfile %>
                    </a>
                  </div>
                </div>
                <% } %>
                <div class="col-sm-6">
                  <label class="detail-label">Position Applied</label>
                  <div class="detail-value d-flex align-items-center gap-2 flex-wrap">
                    <% if (candidate.positionApplying) { %>
                    <span class="badge bg-dark fs-6" id="positionBadge"><%= candidate.positionApplying %></span>
                    <% } else { %>
                    <span class="text-muted" id="positionBadge">Not set</span>
                    <% } %>
                    <select id="positionEditSelect" class="form-select form-select-sm d-none" style="max-width:220px;">
                      <option value="">-- Select Position --</option>
                      <% positions.forEach(p => { %>
                      <option value="<%= p.name %>" <%= candidate.positionApplying === p.name ? 'selected' : '' %>><%= p.name %></option>
                      <% }) %>
                    </select>
                    <button class="btn btn-xs btn-outline-secondary" id="positionEditBtn" onclick="togglePositionEdit()" type="button">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-xs btn-gold d-none" id="positionSaveBtn" onclick="savePosition()" type="button">Save</button>
                  </div>
                </div>
                <div class="col-sm-6">
                  <label class="detail-label">Notice Period</label>
                  <div class="detail-value"><%= candidate.noticePeriod %></div>
                </div>
                <% if (candidate.grade) {
                  const gc = {A:'success',B:'primary',C:'warning',D:'danger'};
                %>
                <div class="col-12">
                  <label class="detail-label">JD Match Grade
                    <% if (candidate.gradeSource === 'ai-analyst') { %>
                    <span class="badge bg-primary ms-1" style="font-size:10px;">ЁЯза Talent Analyst</span>
                    <% } else if (candidate.gradeSource === 'smart-fit') { %>
                    <span class="badge bg-success ms-1" style="font-size:10px;">тнР Smart Fit Analyzer</span>
                    <% } else if (candidate.gradeSource === 'ai') { %>
                    <span class="badge bg-info text-dark ms-1" style="font-size:10px;">ЁЯдЦ AI-graded</span>
                    <% } else { %>
                    <span class="badge bg-secondary ms-1" style="font-size:10px;">ЁЯФС Keyword</span>
                    <% } %>
                  </label>
                  <div class="d-flex align-items-center gap-2 mt-1">
                    <span class="badge bg-<%= gc[candidate.grade]||'secondary' %>" style="font-size:1.4rem;padding:8px 16px;">
                      <%= candidate.grade %>
                    </span>
                    <% if (candidate.gradeScore != null) { %>
                    <span class="text-muted">Score: <strong><%= candidate.gradeScore %>/100</strong></span>
                    <% } %>
                  </div>
                  <% if (candidate.gradeReason) { %>
                  <div class="mt-2 p-2 bg-light rounded small text-muted" style="white-space:pre-wrap;"><%= candidate.gradeReason %></div>
                  <% } %>
                </div>
                <% } %>
                <div class="col-12">
                  <label class="detail-label">Current Package (Annual)</label>
                  <div class="row g-2 mt-1">
                    <div class="col-4">
                      <div class="package-box">
                        <small>Fixed</small>
                        <strong>тВ╣<%= candidate.currentPackage.fixed || 0 %>L</strong>
                      </div>
                    </div>
                    <div class="col-4">
                      <div class="package-box">
                        <small>Variables</small>
                        <strong>тВ╣<%= candidate.currentPackage.variables || 0 %>L</strong>
                      </div>
                    </div>
                    <div class="col-4">
                      <div class="package-box bg-gold-light">
                        <small>Total CTC</small>
                        <strong>тВ╣<%= ((candidate.currentPackage.fixed||0)+(candidate.currentPackage.variables||0)+(candidate.currentPackage.others||0)).toFixed(1) %>L</strong>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Motivational Questions -->
          <% if (candidate.whyJoinUs || candidate.first90DaysPlan) { %>
          <div class="card shadow-sm mb-4">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-chat-quote me-2 text-gold"></i>Candidate Responses</h6></div>
            <div class="card-body">
              <% if (candidate.whyJoinUs) { %>
              <div class="mb-3">
                <label class="detail-label">Why do you want to join us?</label>
                <div class="detail-value mt-1" style="white-space:pre-wrap;"><%= candidate.whyJoinUs %></div>
              </div>
              <% } %>
              <% if (candidate.first90DaysPlan) { %>
              <div class="mb-0">
                <label class="detail-label">Top 3 priorities in first 90 days</label>
                <div class="detail-value mt-1" style="white-space:pre-wrap;"><%= candidate.first90DaysPlan %></div>
              </div>
              <% } %>
            </div>
          </div>
          <% } %>

          <%
            let analystRpt = null;
            try { analystRpt = candidate.analystReport ? JSON.parse(candidate.analystReport) : null; } catch(e) {}
            const confBadge = { High: 'success', Medium: 'warning', Low: 'secondary' };
            const NTL_POS   = 'NEWS TECH LAB- JUNIOR JOURNALIST (20 OPENINGS)- JAIPUR';
            const isNTL     = candidate.positionApplying === NTL_POS;
            const sfData    = typeof sfBreakdown !== 'undefined' ? sfBreakdown : null;
            const lvlColor  = { High:'success', Medium:'warning', Low:'danger' };
            const gc2       = { A:'success', B:'primary', C:'warning', D:'danger' };
          %>

          <% if (isNTL) { %>
          <!-- Smart Fit Analyzer Report (NTL) -->
          <div class="card shadow-sm mb-4" style="border:1.5px solid #28a74540;">
            <div class="card-header d-flex justify-content-between align-items-center" style="background:linear-gradient(90deg,#1b3a1b,#2e5e2e);color:#fff;">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-stars" style="color:#ffd700;font-size:16px;"></i>
                <h6 class="mb-0 text-white">Smart Fit Analyzer Report</h6>
              </div>
              <div class="d-flex align-items-center gap-2">
                <% if (sfData && candidate.grade) { %>
                <%
                  const scoreColor = sfData.total >= 75 ? '#28a745' : sfData.total >= 50 ? '#0d6efd' : sfData.total >= 25 ? '#fd7e14' : '#dc3545';
                  const gradeLabel = { A:'Excellent Fit', B:'Good Fit', C:'Partial Fit', D:'Poor Fit' };
                %>
                <span style="background:rgba(255,255,255,0.15);border-radius:8px;padding:4px 12px;font-size:13px;font-weight:600;color:#fff;">
                  Grade <%= candidate.grade %> &nbsp;┬╖&nbsp; <%= sfData.total %>/100
                  <% if (gradeLabel[candidate.grade]) { %><span style="font-weight:400;font-size:11px;opacity:.85;"> ┬╖ <%= gradeLabel[candidate.grade] %></span><% } %>
                </span>
                <% } %>
              </div>
            </div>

            <% if (!sfData) { %>
            <div class="card-body">
              <p class="text-muted small mb-0">No Smart Fit analysis yet. Click <strong>Re-grade</strong> to analyse this candidate.</p>
            </div>
            <% } else { %>
            <%
              const totalPct = sfData.total || 0;
              const scoreBar = totalPct >= 75 ? 'success' : totalPct >= 50 ? 'primary' : totalPct >= 25 ? 'warning' : 'danger';
              const lvlBg    = { High:'#d4edda', Medium:'#fff3cd', Low:'#f8d7da' };
              const lvlBdr   = { High:'#28a745', Medium:'#ffc107', Low:'#dc3545' };
              const lvlTxt   = { High:'#155724', Medium:'#856404', Low:'#721c24' };
            %>

            <!-- Total score bar -->
            <div style="background:#f0fff2;padding:14px 20px 12px;border-bottom:1px solid #d4edda;">
              <div class="d-flex align-items-center gap-3">
                <span style="font-size:12px;color:#2e5e2e;font-weight:600;min-width:120px;">Overall Fit Score</span>
                <div style="flex:1;">
                  <div class="progress" style="height:12px;border-radius:6px;background:#c3e6cb;">
                    <div class="progress-bar bg-<%= scoreBar %>" style="width:<%= totalPct %>%;border-radius:6px;font-size:10px;line-height:12px;"><%= totalPct %>%</div>
                  </div>
                </div>
                <span style="font-size:20px;font-weight:700;color:#1b3a1b;min-width:70px;text-align:right;"><%= totalPct %><span style="font-size:13px;font-weight:400;color:#555;">/100</span></span>
              </div>
            </div>

            <!-- Summary -->
            <% if (sfData.summary) { %>
            <div style="background:#f8fff8;padding:14px 20px;border-bottom:1px solid #e0f0e0;font-size:13px;line-height:1.7;color:#333;">
              <i class="bi bi-chat-left-quote-fill me-2" style="color:#28a745;"></i><%= sfData.summary %>
            </div>
            <% } %>

            <!-- Parameter cards grid -->
            <% if (Array.isArray(sfData.params) && sfData.params.length) { %>
            <div style="padding:16px 18px;">
              <div style="font-size:10px;font-weight:600;letter-spacing:.08em;color:#2e5e2e;text-transform:uppercase;margin-bottom:12px;">
                <i class="bi bi-bar-chart-line me-1"></i>Parameter Breakdown
              </div>
              <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;">
                <% sfData.params.forEach(function(p) {
                  const bg  = lvlBg[p.level]  || '#f8f9fa';
                  const bdr = lvlBdr[p.level] || '#6c757d';
                  const txt = lvlTxt[p.level] || '#333';
                  const pct = Math.round((p.score / p.max) * 100);
                %>
                <div style="background:<%= bg %>;border:1.5px solid <%= bdr %>30;border-left:4px solid <%= bdr %>;border-radius:8px;padding:12px 14px;">
                  <!-- Header row -->
                  <div class="d-flex align-items-center justify-content-between mb-2">
                    <span style="font-weight:700;font-size:13px;color:#1a1a1a;"><%= p.label %></span>
                    <div class="d-flex align-items-center gap-1">
                      <span style="font-size:13px;font-weight:700;color:<%= bdr %>;"><%= p.score %>/<%= p.max %></span>
                      <span style="background:<%= bdr %>;color:#fff;font-size:9px;font-weight:600;padding:2px 7px;border-radius:10px;"><%= p.level %></span>
                    </div>
                  </div>
                  <!-- Progress bar -->
                  <div style="background:#fff;border-radius:4px;height:6px;margin-bottom:8px;overflow:hidden;">
                    <div style="width:<%= pct %>%;height:100%;background:<%= bdr %>;border-radius:4px;transition:width .4s;"></div>
                  </div>
                  <!-- Reason -->
                  <% if (p.reason) { %>
                  <div style="font-size:11.5px;color:<%= txt %>;line-height:1.5;"><%= p.reason %></div>
                  <% } %>
                  <!-- Weight footnote -->
                  <div style="margin-top:8px;padding-top:6px;border-top:1px solid <%= bdr %>25;display:flex;justify-content:space-between;font-size:10px;color:#777;">
                    <span>Weight: <strong><%= p.weight %>%</strong></span>
                    <span>Contribution: <strong><%= p.weighted %> pts</strong></span>
                  </div>
                </div>
                <% }); %>
              </div>
            </div>
            <% } %>
            <% } %>
          </div>

          <% } else { %>
          <!-- AI Talent Analyst Report (non-NTL positions) -->
          <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h6 class="mb-0"><i class="bi bi-cpu me-2 text-gold"></i>AI Talent Analyst Report</h6>
              <div class="d-flex align-items-center gap-2">
                <% if (analystRpt) { %>
                <span class="badge bg-<%= {A:'success',B:'primary',C:'warning'}[analystRpt.tier] || 'secondary' %>">
                  Tier <%= analystRpt.tier %> ┬╖ <%= analystRpt.weightedTotal %>/100
                </span>
                <span class="badge bg-secondary"><i class="bi bi-lock-fill me-1"></i>Locked</span>
                <% } else { %>
                <button class="btn btn-sm btn-outline-primary" id="runAnalystBtn" onclick="runAnalyst()">
                  <i class="bi bi-play-fill me-1"></i>Run Analysis
                </button>
                <% } %>
              </div>
            </div>
            <div class="card-body">
              <% if (!analystRpt) { %>
              <p class="text-muted small mb-0">
                No analyst report yet. Click <strong>Run Analysis</strong> to evaluate this candidate with the
                Talent Analyst rubric (Relevant Experience 30%, Skills Match 25%, Leadership & Scope 20%,
                Motivation & Culture Fit 15%, Compensation Alignment 10%).
              </p>
              <% } else { %>
              <p class="small mb-3"><strong>Summary:</strong> <%= analystRpt.summary %></p>
              <% if (Array.isArray(analystRpt.dimensions) && analystRpt.dimensions.length) { %>
              <div class="table-responsive mb-3">
                <table class="table table-sm table-bordered align-middle mb-0">
                  <thead class="table-dark">
                    <tr><th>Dimension</th><th class="text-center">Weight</th><th class="text-center">Score (1тАУ5)</th><th class="text-center">Weighted</th><th>Evidence</th><th class="text-center">Confidence</th></tr>
                  </thead>
                  <tbody>
                    <% analystRpt.dimensions.forEach(d => { %>
                    <tr>
                      <td class="fw-semibold"><%= d.name %></td>
                      <td class="text-center"><%= d.weight %>%</td>
                      <td class="text-center"><span class="badge bg-<%= d.score >= 4 ? 'success' : d.score >= 3 ? 'primary' : d.score >= 2 ? 'warning' : 'danger' %>"><%= d.score %></span></td>
                      <td class="text-center"><%= d.weightedScore %></td>
                      <td class="small"><%= d.evidence %></td>
                      <td class="text-center"><span class="badge bg-<%= confBadge[d.confidence] || 'secondary' %>"><%= d.confidence %></span></td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <% } %>
              <div class="row g-3">
                <% if (Array.isArray(analystRpt.strengths) && analystRpt.strengths.length) { %>
                <div class="col-md-6">
                  <label class="detail-label text-success"><i class="bi bi-hand-thumbs-up me-1"></i>Strengths</label>
                  <ul class="small mb-0 mt-1 ps-3">
                    <% analystRpt.strengths.forEach(s => { %>
                    <li class="mb-1"><%= s.point %> <span class="text-muted">(<%= s.evidence %>)</span>
                      <span class="badge bg-<%= confBadge[s.confidence] || 'secondary' %>" style="font-size:9px;"><%= s.confidence %></span></li>
                    <% }) %>
                  </ul>
                </div>
                <% } %>
                <% if (Array.isArray(analystRpt.concerns) && analystRpt.concerns.length) { %>
                <div class="col-md-6">
                  <label class="detail-label text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Concerns</label>
                  <ul class="small mb-0 mt-1 ps-3">
                    <% analystRpt.concerns.forEach(cn => { %>
                    <li class="mb-1"><%= cn.point %> <span class="text-muted">(<%= cn.evidence %>)</span>
                      <span class="badge bg-<%= confBadge[cn.confidence] || 'secondary' %>" style="font-size:9px;"><%= cn.confidence %></span></li>
                    <% }) %>
                  </ul>
                </div>
                <% } %>
                <% if (Array.isArray(analystRpt.interviewVerify) && analystRpt.interviewVerify.length) { %>
                <div class="col-md-6">
                  <label class="detail-label text-primary"><i class="bi bi-patch-question me-1"></i>Verify in Interview</label>
                  <ul class="small mb-0 mt-1 ps-3">
                    <% analystRpt.interviewVerify.forEach(v => { %><li class="mb-1"><%= v %></li><% }) %>
                  </ul>
                </div>
                <% } %>
                <% if (Array.isArray(analystRpt.missingData) && analystRpt.missingData.length) { %>
                <div class="col-md-6">
                  <label class="detail-label"><i class="bi bi-question-circle me-1"></i>Missing Data</label>
                  <ul class="small mb-0 mt-1 ps-3 text-muted">
                    <% analystRpt.missingData.forEach(m => { %><li class="mb-1"><%= m %></li><% }) %>
                  </ul>
                </div>
                <% } %>
              </div>
              <% } %>
            </div>
          </div>
          <% } %>

          <% if (candidate.positionApplying === 'NEWS TECH LAB- JUNIOR JOURNALIST (20 OPENINGS)- JAIPUR') { %>
          <!-- News Tech Lab Interview + GD Invite -->
          <div class="card shadow-sm mb-4 border-gold">
            <div class="card-header d-flex justify-content-between align-items-center bg-gold-light">
              <h6 class="mb-0"><i class="bi bi-newspaper me-2 text-gold"></i>News Tech Lab тАФ Interview &amp; GD Invite</h6>
              <% if (candidate.ntlInviteSentAt) { %>
              <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Sent <%= new Date(candidate.ntlInviteSentAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
              <% } else { %>
              <span class="badge bg-secondary">Not Sent</span>
              <% } %>
            </div>
            <div class="card-body">
              <div class="row g-2 mb-3">
                <div class="col-md-6">
                  <label class="form-label small fw-semibold">Interview Date &amp; Time</label>
                  <input type="text" class="form-control form-control-sm" id="ntlInterviewDate" placeholder="e.g. 25 July 2025, 10:00 AM" value="<%= candidate.ntlInterviewDate || '' %>">
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-semibold">Slot / Candidate No.</label>
                  <input type="text" class="form-control form-control-sm" id="ntlInterviewSlot" placeholder="e.g. Slot 3 / Candidate #12" value="<%= candidate.ntlInterviewSlot || '' %>">
                </div>
                <div class="col-12">
                  <label class="form-label small fw-semibold">Interview Link</label>
                  <input type="url" class="form-control form-control-sm" id="ntlInterviewLink" placeholder="https://meet.google.com/..." value="<%= candidate.ntlInterviewLink || '' %>">
                </div>
                <div class="col-12">
                  <label class="form-label small fw-semibold">Group Discussion Sheet Link</label>
                  <input type="url" class="form-control form-control-sm" id="ntlGDLink" placeholder="https://docs.google.com/..." value="<%= candidate.ntlGDLink || '' %>">
                </div>
              </div>
              <div class="d-flex gap-2 align-items-center">
                <button class="btn btn-sm btn-gold" onclick="sendNTLInvite()" id="ntlSendBtn">
                  <i class="bi bi-send-fill me-1"></i>Save &amp; Send Email
                </button>
                <button class="btn btn-sm btn-outline-secondary" onclick="saveNTLOnly()" id="ntlSaveBtn">
                  <i class="bi bi-floppy me-1"></i>Save Only
                </button>
              </div>
              <div id="ntlResult" class="mt-2"></div>
            </div>
          </div>
          <% } %>

          <!-- Personal Detail Form -->
          <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h6 class="mb-0"><i class="bi bi-file-person me-2 text-gold"></i>Personal Detail Form</h6>
              <% if (detailForm && detailForm.status === 'submitted') { %>
              <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Submitted</span>
              <% } else if (detailForm && detailForm.status === 'pending') { %>
              <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pending Response</span>
              <% } else { %>
              <span class="badge bg-secondary">Not Sent</span>
              <% } %>
            </div>
            <div class="card-body">
              <% if (detailForm && detailForm.status === 'submitted') { %>
              <p class="text-muted small mb-2">Submitted on <%= new Date(detailForm.submittedAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></p>
              <div class="d-flex gap-2">
                <a href="/admin/candidate/<%= candidate.id %>/detail-form" class="btn btn-sm btn-gold">
                  <i class="bi bi-eye me-1"></i>View Filled Form
                </a>
                <button class="btn btn-sm btn-outline-secondary" id="resendFormBtn" onclick="sendDetailForm()">
                  <i class="bi bi-send me-1"></i>Resend Form
                </button>
              </div>
              <% } else if (detailForm && detailForm.status === 'pending') { %>
              <p class="text-muted small mb-2">
                Link sent тАУ expires <%= new Date(detailForm.tokenExpiresAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>.
                Candidate has not filled it yet.
              </p>
              <button class="btn btn-sm btn-outline-secondary" id="resendFormBtn" onclick="sendDetailForm()">
                <i class="bi bi-send me-1"></i>Resend New Link
              </button>
              <% } else { %>
              <p class="text-muted small mb-3">Send the Personal Detail Form link to the candidate's email. They will fill it online and the response will be saved here.</p>
              <button class="btn btn-sm btn-gold" id="sendFormBtn" onclick="sendDetailForm()">
                <i class="bi bi-send me-1"></i>Send Detail Form to Candidate
              </button>
              <% } %>
              <div id="formSendResult" class="mt-2"></div>
            </div>
          </div>

          <!-- Test History Card -->
          <div class="card shadow-sm mb-4" id="testHistoryCard">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h6 class="mb-0"><i class="bi bi-ui-checks me-2 text-gold"></i>Assessment Tests</h6>
              <button class="btn btn-xs btn-sm btn-outline-gold py-0 px-2" onclick="sendTest()" id="sendTestBtn2">
                <i class="bi bi-send me-1"></i>Send New Test
              </button>
            </div>
            <div class="card-body p-0" id="testHistoryBody">
              <div class="text-center text-muted py-3 small"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</div>
            </div>
          </div>

          <!-- Resume Card -->
          <div class="card shadow-sm mb-4">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-file-earmark-person me-2"></i>Resume / CV</h6></div>
            <div class="card-body">
              <% if (candidate.resumeFile) {
                   const ext = candidate.resumeFile.originalName.split('.').pop().toLowerCase();
                   const iconClass = ext === 'pdf' ? 'pdf' : 'docx';
                   const icon = ext === 'pdf' ? 'bi-file-earmark-pdf-fill' : 'bi-file-earmark-word-fill';
              %>
              <div class="resume-card">
                <i class="bi <%= icon %> file-icon <%= iconClass %>"></i>
                <div class="flex-grow-1">
                  <div class="fw-semibold"><%= candidate.resumeFile.originalName %></div>
                  <small class="text-muted">
                    <%= (candidate.resumeFile.size / 1024).toFixed(1) %> KB &nbsp;┬╖&nbsp;
                    <%= ext.toUpperCase() %> file
                  </small>
                </div>
                <div class="d-flex gap-2">
                  <button class="btn btn-gold btn-sm" onclick="openPreview()">
                    <i class="bi bi-eye me-1"></i>Preview
                  </button>
                  <a href="/admin/candidate/<%= candidate.id %>/download" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-download me-1"></i>Download
                  </a>
                </div>
              </div>
              <% } else { %>
              <div class="text-center text-muted py-4">
                <i class="bi bi-file-earmark-x display-5 d-block mb-2"></i>
                No resume uploaded by this candidate.
              </div>
              <% } %>
            </div>
          </div>

          <!-- Parsed Data Card -->
          <% const pd = candidate.parsedData;
             const hasAnyParsed = pd && (pd.name || pd.email || pd.totalExperience || pd.currentRole || pd.summary || pd.linkedin || (pd.skills && pd.skills.length) || (pd.experienceEntries && pd.experienceEntries.length) || (pd.education && pd.education.length));
          %>
          <% if (hasAnyParsed) { %>
          <div class="card shadow-sm mb-4 border-gold">
            <div class="card-header bg-gold-light">
              <h6 class="mb-0 text-dark"><i class="bi bi-magic me-2"></i>Resume Intelligence</h6>
            </div>
            <div class="card-body">

              <!-- Basic parsed info -->
              <div class="row g-3 mb-3">
                <% if (pd.totalExperience) { %>
                <div class="col-sm-6">
                  <label class="detail-label">Total Experience</label>
                  <div class="detail-value fw-semibold text-gold"><%= pd.totalExperience %></div>
                </div>
                <% } %>
                <% if (pd.currentRole) { %>
                <div class="col-sm-6">
                  <label class="detail-label">Current / Last Role</label>
                  <div class="detail-value"><%= pd.currentRole %></div>
                </div>
                <% } %>
                <% if (pd.linkedin) { %>
                <div class="col-12">
                  <label class="detail-label">LinkedIn</label>
                  <div class="detail-value"><a href="<%= pd.linkedin %>" target="_blank" class="text-gold"><%= pd.linkedin %></a></div>
                </div>
                <% } %>
                <% if (pd.summary) { %>
                <div class="col-12">
                  <label class="detail-label">Profile Summary</label>
                  <div class="detail-value small" style="line-height:1.6;"><%= pd.summary %></div>
                </div>
                <% } %>
              </div>

              <!-- Work Experience -->
              <% if (pd.experienceEntries && pd.experienceEntries.length) { %>
              <div class="mb-3">
                <label class="detail-label mb-2 d-block"><i class="bi bi-briefcase me-1"></i>Work Experience</label>
                <% pd.experienceEntries.forEach(e => { %>
                <div style="border-left:3px solid #d4a017;padding-left:12px;margin-bottom:10px;">
                  <div class="fw-semibold small"><%= e.role || '' %></div>
                  <div class="text-muted small"><%= e.company || '' %></div>
                  <div style="font-size:11px;color:#d4a017;font-weight:600;"><%= e.period || '' %></div>
                  <% if (e.description && e.description.length) { %>
                  <ul class="mb-0 mt-1 small text-muted ps-3">
                    <% e.description.slice(0,2).forEach(b => { %><li><%= b %></li><% }) %>
                  </ul>
                  <% } %>
                </div>
                <% }) %>
              </div>
              <% } %>

              <!-- Education -->
              <% if (pd.education && pd.education.length) { %>
              <div class="mb-3">
                <label class="detail-label mb-2 d-block"><i class="bi bi-mortarboard me-1"></i>Education / Qualification</label>
                <% pd.education.forEach(e => { %>
                <div style="border-left:3px solid #1a1a2e;padding-left:12px;margin-bottom:8px;">
                  <div class="fw-semibold small"><%= e.degree %></div>
                  <% if (e.institution) { %><div class="text-muted small"><%= e.institution %></div><% } %>
                  <% if (e.year) { %><div style="font-size:11px;color:#d4a017;"><%= e.year %></div><% } %>
                </div>
                <% }) %>
              </div>
              <% } %>

              <!-- Skills -->
              <% if (pd.skills && pd.skills.length) { %>
              <div>
                <label class="detail-label mb-2 d-block"><i class="bi bi-tags me-1"></i>Extracted Skills</label>
                <% pd.skills.forEach(skill => { %>
                <span class="badge bg-secondary me-1 mb-1"><%= skill %></span>
                <% }) %>
              </div>
              <% } %>

            </div>
          </div>
          <% } %>

          <!-- Communication Log -->
          <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h6 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Communication History</h6>
              <span class="badge bg-secondary"><%= candidate.communications.length %> messages</span>
            </div>
            <div class="card-body p-0">
              <% if (candidate.communications.length === 0) { %>
              <div class="text-center text-muted py-4">
                <i class="bi bi-chat-square display-6 d-block mb-2"></i>No communications sent yet.
              </div>
              <% } else { %>
              <div class="comm-log">
                <% candidate.communications.slice().reverse().forEach(c => { %>
                <% const isReply = c.direction === 'inbound'; %>
                <div class="comm-entry" <%= isReply ? 'style="background:#fff8ee;border-left:3px solid #fd7e14;"' : '' %>>
                  <div class="d-flex align-items-center gap-2 mb-1">
                    <% if (isReply) { %>
                    <span class="badge" style="background:#fd7e14;">
                      <i class="bi bi-envelope-arrow-down me-1"></i>Reply from Candidate
                    </span>
                    <% } else { %>
                    <span class="badge bg-<%= c.channel === 'WhatsApp' ? 'success' : 'primary' %>">
                      <i class="bi bi-<%= c.channel === 'WhatsApp' ? 'whatsapp' : 'envelope' %> me-1"></i><%= c.channel %>
                    </span>
                    <% } %>
                    <small class="text-muted"><%= new Date(c.sentAt).toLocaleString('en-IN') %></small>
                    <% if (!isReply) { %>
                    <span class="badge bg-<%= c.status === 'Sent' ? 'success' : 'danger' %> ms-auto" style="font-size:10px;"><%= c.status %></span>
                    <% } %>
                  </div>
                  <% if (c.subject) { %><div class="small fw-semibold text-muted mb-1"><%= isReply ? '' : 'Re: ' %><%= c.subject %></div><% } %>
                  <div class="comm-message"><%= c.message %></div>
                </div>
                <% }) %>
              </div>
              <% } %>
            </div>
          </div>

        </div>

        <!-- ├втАЭтВм├втАЭтВм Right Column ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
        <div class="col-lg-5">

          <!-- Pipeline Status -->
          <div class="card shadow-sm mb-4">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Update Status & Notes</h6></div>
            <div class="card-body">
              <form action="/admin/candidate/<%= candidate.id %>/update" method="POST">
                <div class="mb-3">
                  <label class="form-label fw-semibold">Pipeline Status</label>
                  <% const statusOpts = ['New','Screening','Shortlisted','Interview Scheduled','Offer Extended','Hired','Rejected'];
                     const sColor = { New:'primary', Screening:'info', Shortlisted:'warning', 'Interview Scheduled':'secondary', 'Offer Extended':'dark', Hired:'success', Rejected:'danger' }; %>
                  <div class="d-flex flex-wrap gap-1 mb-2">
                    <% statusOpts.forEach(s => { %>
                    <input type="radio" class="btn-check" name="status" id="status_<%= s.replace(/\s/g,'_') %>"
                      value="<%= s %>" <%= candidate.status === s ? 'checked' : '' %>>
                    <label class="btn btn-sm btn-outline-<%= sColor[s] %>" for="status_<%= s.replace(/\s/g,'_') %>">
                      <%= s %>
                    </label>
                    <% }) %>
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">Admin Notes</label>
                  <textarea class="form-control" name="adminNotes" rows="4"
                    placeholder="Add notes about this candidate..."><%= candidate.adminNotes || '' %></textarea>
                </div>
                <button type="submit" class="btn btn-gold w-100">
                  <i class="bi bi-save me-1"></i>Save Changes
                </button>
              </form>
            </div>
          </div>

          <!-- Send Communication -->
          <div class="card shadow-sm">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-send me-2"></i>Send Message</h6></div>
            <div class="card-body">
              <div id="commAlert" class="d-none mb-2"></div>
              <div class="mb-3">
                <label class="form-label fw-semibold">Channel</label>
                <div class="d-flex gap-2">
                  <input type="radio" class="btn-check" name="commChannel" id="chEmail" value="Email" checked>
                  <label class="btn btn-outline-primary flex-fill" for="chEmail">
                    <i class="bi bi-envelope me-1"></i>Email
                  </label>
                  <input type="radio" class="btn-check" name="commChannel" id="chWhatsApp" value="WhatsApp">
                  <label class="btn btn-outline-success flex-fill" for="chWhatsApp">
                    <i class="bi bi-whatsapp me-1"></i>WhatsApp
                  </label>
                </div>
              </div>
              <div class="mb-3" id="subjectField">
                <label class="form-label">Subject</label>
                <input type="text" class="form-control" id="commSubject" value="Message from Patrika HR">
              </div>
              <div class="mb-2">
                <label class="form-label fw-semibold">Quick Templates</label>
                <select class="form-select form-select-sm" id="msgTemplate">
                  <option value="">-- Choose a template --</option>
                  <option value="Dear <%= candidate.fullName %>,\n\nThank you for applying for the <%= candidate.positionApplying %> position at Patrika Group. We have received your application and our team will review it shortly.\n\nWarm regards,\nPatrika HR Team">Application Confirmation</option>
                  <option value="Dear <%= candidate.fullName %>,\n\nWe are pleased to inform you that your profile has been shortlisted for the <%= candidate.positionApplying %> position. Our HR team will contact you shortly to schedule an interview.\n\nBest regards,\nPatrika HR Team">Shortlisting Confirmation</option>
                  <option value="Dear <%= candidate.fullName %>,\n\nWe would like to invite you for an interview for the <%= candidate.positionApplying %> position.\n\nDate & Time: [Please specify]\nVenue: Patrika Bhawan, Jaipur\n\nKindly confirm your availability.\n\nBest regards,\nPatrika HR Team">Interview Invite</option>
                  <option value="Dear <%= candidate.fullName %>,\n\nThank you for your time and interest in Patrika Group. After careful consideration, we regret to inform you that we will not be moving forward with your application at this time.\n\nWe wish you the best in your career journey.\n\nWarm regards,\nPatrika HR Team">Rejection (Polite)</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label fw-semibold">Message *</label>
                <textarea class="form-control" id="commMessage" rows="5" placeholder="Type your message here..."></textarea>
              </div>
              <button class="btn btn-gold w-100" id="sendCommBtn" onclick="sendCommunication()">
                <i class="bi bi-send-fill me-1"></i>Send Message
              </button>
              <p class="text-muted small text-center mt-2">
                <i class="bi bi-info-circle me-1"></i>
                To: <strong><%= candidate.email %></strong> &nbsp;/&nbsp; <strong><%= candidate.contactNumber %></strong>
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>
</div>

<!-- ├втАв┬Р├втАв┬Р RESUME PREVIEW MODAL ├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р -->
<% if (candidate.resumeFile) { %>
<div class="modal fade resume-preview-modal" id="resumeModal" tabindex="-1" aria-labelledby="resumeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <div class="d-flex align-items-center gap-2">
          <i class="bi bi-file-earmark-person text-gold fs-5"></i>
          <h6 class="modal-title mb-0" id="resumeModalLabel"><%= candidate.resumeFile.originalName %></h6>
          <span class="badge bg-secondary ms-1"><%= candidate.fullName %></span>
        </div>
        <div class="d-flex gap-2 ms-auto me-2">
          <a href="/admin/candidate/<%= candidate.id %>/download" class="btn btn-sm btn-outline-success">
            <i class="bi bi-download me-1"></i>Download
          </a>
          <a href="/admin/candidate/<%= candidate.id %>/preview" target="_blank" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-box-arrow-up-right me-1"></i>Open in New Tab
          </a>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="clearPreview()"></button>
      </div>
      <div class="modal-body p-0" style="background:#525659;">
        <div id="previewLoading" class="text-center text-white py-5">
          <div class="spinner-border text-light mb-2"></div>
          <div>Loading resume...</div>
        </div>
        <iframe id="resumeFrame" class="resume-iframe" style="display:none;"
          title="Resume Preview"></iframe>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Download Documents Bundle Modal -->
<div class="modal fade" id="downloadBundleModal" tabindex="-1" aria-labelledby="downloadBundleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="downloadBundleModalLabel"><i class="bi bi-archive me-2 text-warning"></i>Download Document Bundle</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small mb-3">Select the documents to include in the ZIP bundle for <strong><%= candidate.fullName %></strong>:</p>
        <div class="d-flex flex-column gap-2">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="dlResume" value="resume" <%= candidate.resumeFile ? 'checked' : '' %>>
            <label class="form-check-label" for="dlResume">
              <i class="bi bi-file-earmark-pdf me-1 text-danger"></i>Resume
              <% if (!candidate.resumeFile) { %><span class="text-muted small">(not uploaded)</span><% } %>
            </label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="dlInterview" value="interview" checked>
            <label class="form-check-label" for="dlInterview">
              <i class="bi bi-clipboard-check me-1 text-primary"></i>Interview Sheet
            </label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="dlDetailForm" value="detail_form" checked>
            <label class="form-check-label" for="dlDetailForm">
              <i class="bi bi-person-lines-fill me-1 text-info"></i>Personal Detail Form
            </label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="dlTimeline" value="timeline" checked>
            <label class="form-check-label" for="dlTimeline">
              <i class="bi bi-clock-history me-1 text-success"></i>Activity History
            </label>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-warning btn-sm" onclick="doSingleDownload()">
          <i class="bi bi-download me-1"></i>Download ZIP
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // ├втАЭтВм├втАЭтВм Resume Preview ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  <% if (candidate.resumeFile) { %>
  const previewUrl = '/admin/candidate/<%= candidate.id %>/preview';
  let previewLoaded = false;

  function openPreview() {
    const modal = new bootstrap.Modal(document.getElementById('resumeModal'));
    modal.show();
    if (!previewLoaded) {
      const frame  = document.getElementById('resumeFrame');
      const loader = document.getElementById('previewLoading');
      frame.src = previewUrl;
      frame.onload = () => {
        loader.style.display = 'none';
        frame.style.display  = 'block';
        previewLoaded = true;
      };
      frame.onerror = () => {
        loader.innerHTML = '<div class="text-danger mt-3"><i class="bi bi-exclamation-circle fs-3 d-block mb-2"></i>Could not load preview.<br><a href="' + previewUrl + '" target="_blank" class="btn btn-sm btn-light mt-2">Open in New Tab</a></div>';
      };
    }
  }

  function clearPreview() {
    // Reset so next open re-loads (in case the file was updated)
    previewLoaded = false;
    document.getElementById('resumeFrame').src = '';
    document.getElementById('resumeFrame').style.display = 'none';
    document.getElementById('previewLoading').style.display = 'block';
  }

  // Also open modal if URL has ?preview=1
  if (window.location.search.includes('preview=1')) openPreview();
  <% } %>

  // ├втАЭтВм├втАЭтВм Templates ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  document.getElementById('msgTemplate').addEventListener('change', function () {
    if (this.value) document.getElementById('commMessage').value = this.value.replace(/\\n/g, '\n');
  });

  document.querySelectorAll('input[name="commChannel"]').forEach(el => {
    el.addEventListener('change', function () {
      document.getElementById('subjectField').style.display =
        this.value === 'WhatsApp' ? 'none' : 'block';
    });
  });

  // ├втАЭтВм├втАЭтВм Send Communication ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  function sendCommunication() {
    const channel = document.querySelector('input[name="commChannel"]:checked').value;
    const message = document.getElementById('commMessage').value.trim();
    const subject = document.getElementById('commSubject').value;
    if (!message) { alert('Please enter a message.'); return; }

    const btn = document.getElementById('sendCommBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';

    fetch('/admin/candidate/<%= candidate.id %>/communicate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ channel, message, subject })
    })
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('commAlert');
      el.className = `alert alert-${data.success ? 'success' : 'danger'} py-2`;
      el.textContent = data.message;
      el.classList.remove('d-none');
      if (data.success) {
        document.getElementById('commMessage').value = '';
        setTimeout(() => location.reload(), 1500);
      }
    })
    .finally(() => {
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Send Message';
    });
  }

  // ├втАЭтВм├втАЭтВм Delete Candidate ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  function deleteCandidate(id) {
    if (!confirm('Delete this candidate permanently? This cannot be undone.')) return;
    fetch(`/admin/candidate/${id}`, { method: 'DELETE' })
      .then(r => r.json())
      .then(d => {
        if (d.success) window.location = '/admin/dashboard';
        else alert('Delete failed: ' + d.message);
      });
  }

  async function sendNTLInvite() {
    const payload = {
      interviewDate: document.getElementById('ntlInterviewDate').value.trim(),
      interviewSlot: document.getElementById('ntlInterviewSlot').value.trim(),
      interviewLink: document.getElementById('ntlInterviewLink').value.trim(),
      gdLink:        document.getElementById('ntlGDLink').value.trim(),
    };
    if (!payload.interviewLink && !payload.gdLink)
      return alert('Please enter at least an Interview Link or GD Sheet Link.');
    const btn = document.getElementById('ntlSendBtn');
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';
    try {
      const r = await fetch('/admin/candidate/<%= candidate.id %>/ntl-invite', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
      });
      const d = await r.json();
      const el = document.getElementById('ntlResult');
      if (d.success) {
        el.innerHTML = `<div class="alert alert-success py-2 small mb-0"><i class="bi bi-check-circle me-1"></i>${d.message}</div>`;
        setTimeout(() => location.reload(), 1500);
      } else {
        el.innerHTML = `<div class="alert alert-danger py-2 small mb-0">${d.message}</div>`;
        btn.disabled = false; btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Save &amp; Send Email';
      }
    } catch(e) {
      document.getElementById('ntlResult').innerHTML = `<div class="alert alert-danger py-2 small mb-0">Network error: ${e.message}</div>`;
      btn.disabled = false; btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Save &amp; Send Email';
    }
  }

  async function saveNTLOnly() {
    const payload = {
      interviewDate: document.getElementById('ntlInterviewDate').value.trim(),
      interviewSlot: document.getElementById('ntlInterviewSlot').value.trim(),
      interviewLink: document.getElementById('ntlInterviewLink').value.trim(),
      gdLink:        document.getElementById('ntlGDLink').value.trim(),
      saveOnly: true
    };
    const btn = document.getElementById('ntlSaveBtn');
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
    try {
      const r = await fetch('/admin/candidate/<%= candidate.id %>/ntl-invite?saveOnly=1', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
      });
      const d = await r.json();
      const el = document.getElementById('ntlResult');
      if (d.success) {
        el.innerHTML = `<div class="alert alert-success py-2 small mb-0"><i class="bi bi-check-circle me-1"></i>Details saved.</div>`;
        setTimeout(() => location.reload(), 1000);
      } else {
        el.innerHTML = `<div class="alert alert-danger py-2 small mb-0">${d.message}</div>`;
      }
    } catch(e) {
      document.getElementById('ntlResult').innerHTML = `<div class="alert alert-danger py-2 small mb-0">Network error</div>`;
    }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-floppy me-1"></i>Save Only';
  }

  async function sendDetailForm() {
    const btn = document.getElementById('sendFormBtn') || document.getElementById('resendFormBtn');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...'; }
    try {
      const r = await fetch('/admin/candidate/<%= candidate.id %>/send-detail-form', { method: 'POST' });
      const d = await r.json();
      const el = document.getElementById('formSendResult');
      if (d.success) {
        if (el) el.innerHTML = `<div class="alert alert-success py-2 small mb-0"><i class="bi bi-check-circle me-1"></i>${d.message}</div>`;
        setTimeout(() => location.reload(), 1500);
      } else {
        if (el) el.innerHTML = `<div class="alert alert-danger py-2 small mb-0">${d.message}</div>`;
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-send me-1"></i>Send Detail Form'; }
      }
    } catch(e) {
      const el = document.getElementById('formSendResult');
      if (el) el.innerHTML = `<div class="alert alert-danger py-2 small mb-0">Network error: ${e.message}</div>`;
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-send me-1"></i>Send Detail Form'; }
    }
  }

  // тФАтФА AI Talent Analyst тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  async function runAnalyst(force) {
    const hasExisting = <%= analystRpt ? 'true' : 'false' %>;
    // If report exists and not forcing, confirm before re-running
    if (hasExisting && !force) {
      if (!confirm('This candidate already has a graded report.\n\nRe-analysing will overwrite the existing score and may give a slightly different result.\n\nAre you sure you want to re-analyse?')) return;
      return runAnalyst(true);
    }
    const btn = document.getElementById('runAnalystBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Analysing...';
    const url = '/admin/candidate/<%= candidate.id %>/grade' + (force ? '?force=1' : '');
    try {
      const r = await fetch(url, { method: 'POST' });
      const d = await r.json();
      if (d.success) {
        location.reload();
      } else {
        alert('Analysis failed: ' + (d.error || 'Unknown error'));
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-arrow-repeat me-1"></i><%= analystRpt ? "Re-analyse" : "Run Analysis" %>';
      }
    } catch(e) {
      alert('Network error: ' + e.message);
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-arrow-repeat me-1"></i><%= analystRpt ? "Re-analyse" : "Run Analysis" %>';
    }
  }

  // тФАтФА Smart Fit Grade (NTL position) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  async function runSmartFitGrade() {
    const btn = document.getElementById('runSmartFitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Grading...';
    try {
      const r = await fetch('/admin/candidate/<%= candidate.id %>/grade', { method: 'POST' });
      const d = await r.json();
      if (d.success) {
        location.reload();
      } else {
        alert('Smart Fit grading failed: ' + (d.error || 'Unknown error'));
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-stars me-1"></i>Grade with Smart Fit';
      }
    } catch(e) {
      alert('Network error: ' + e.message);
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-stars me-1"></i>Grade with Smart Fit';
    }
  }

  // тФАтФА Document Bundle Download тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  function doSingleDownload() {
    const checkboxes = document.querySelectorAll('#downloadBundleModal input[type=checkbox]:checked');
    const docs = [...checkboxes].map(cb => cb.value);
    if (!docs.length) { alert('Please select at least one document type.'); return; }
    const qs = docs.join(',');
    window.location = '/admin/candidate/<%= candidate.id %>/download-bundle?docs=' + encodeURIComponent(qs);
    // Close modal after short delay
    setTimeout(() => {
      const modal = bootstrap.Modal.getInstance(document.getElementById('downloadBundleModal'));
      if (modal) modal.hide();
    }, 500);
  }

function togglePositionEdit() {
  const badge  = document.getElementById('positionBadge');
  const select = document.getElementById('positionEditSelect');
  const saveBtn = document.getElementById('positionSaveBtn');
  const editBtn = document.getElementById('positionEditBtn');
  const editing = select.classList.contains('d-none');
  badge.classList.toggle('d-none', editing);
  select.classList.toggle('d-none', !editing);
  saveBtn.classList.toggle('d-none', !editing);
  editBtn.innerHTML = editing ? '<i class="bi bi-x"></i>' : '<i class="bi bi-pencil"></i>';
}

async function savePosition() {
  const pos = document.getElementById('positionEditSelect').value;
  const btn = document.getElementById('positionSaveBtn');
  btn.disabled = true;
  try {
    const r = await fetch('/admin/candidate/<%= candidate.id %>/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        status: '<%= candidate.status %>',
        adminNotes: document.getElementById('adminNotes') ? document.getElementById('adminNotes').value : '<%= (candidate.adminNotes||"").replace(/'/g, "\\'") %>',
        positionApplying: pos
      })
    });
    const d = await r.json();
    if (d.success || r.ok) {
      const badge = document.getElementById('positionBadge');
      badge.textContent = pos || 'Not set';
      badge.className = pos ? 'badge bg-dark fs-6' : 'text-muted';
      togglePositionEdit();
    } else { alert('Failed to save'); }
  } catch(e) { alert('Network error'); }
  btn.disabled = false;
}

// тФАтФА Assessment Test тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
async function sendTest() {
  const btns = document.querySelectorAll('#sendTestBtn, #sendTestBtn2');
  btns.forEach(b => { b.disabled = true; b.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating...'; });
  try {
    const r = await fetch('/admin/candidate/<%= candidate.id %>/send-test', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const d = await r.json();
    if (d.success) {
      alert(d.emailSent ? 'Test generated and sent to candidate\'s email!' : 'Test generated! (Email delivery failed тАФ check server email config)');
      loadTestHistory();
    } else {
      alert(d.error || 'Failed to generate test');
    }
  } catch(e) { alert('Network error: ' + e.message); }
  btns.forEach(b => { b.disabled = false; b.innerHTML = '<i class="bi bi-ui-checks me-1"></i>Send Test'; });
}

function goBack() {
  if (document.referrer && new URL(document.referrer).origin === location.origin && history.length > 1) {
    history.back();
  } else {
    location.href = '/admin/candidates';
  }
}

async function loadTestHistory() {
  const body = document.getElementById('testHistoryBody');
  try {
    const r = await fetch('/admin/candidate/<%= candidate.id %>/tests');
    const d = await r.json();
    if (!d.tests || d.tests.length === 0) {
      body.innerHTML = '<p class="text-muted text-center py-3 mb-0 small">No tests sent yet.</p>';
      return;
    }
    const rows = d.tests.map((t, i) => {
      const status = t.status === 'completed'
        ? `<span class="badge bg-success">Completed</span>`
        : `<span class="badge bg-warning text-dark">Pending</span>`;
      const score = t.score !== null
        ? `<strong class="text-gold">${t.score}/${t.maxScore}</strong> <span class="badge bg-${t.score >= 80 ? 'success' : t.score >= 50 ? 'warning text-dark' : 'danger'}">${t.score >= 80 ? 'A' : t.score >= 65 ? 'B' : t.score >= 50 ? 'C' : 'D'}</span>`
        : 'тАФ';
      const link = t.status === 'completed'
        ? `<a href="/admin/test-result/${t.id}" class="btn btn-xs btn-sm btn-outline-gold py-0 px-2" target="_blank">View Result</a>`
        : `<span class="text-muted small">Awaiting submission</span>`;
      const date = new Date(t.sentAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
      return `<tr><td class="ps-3 small text-muted">${date}</td><td class="small">${t.positionName}</td><td>${status}</td><td>${score}</td><td>${link}</td></tr>`;
    }).join('');
    body.innerHTML = `<table class="table table-hover mb-0 small"><thead class="table-light"><tr><th class="ps-3">Sent</th><th>Position</th><th>Status</th><th>Score</th><th>Action</th></tr></thead><tbody>${rows}</tbody></table>`;
  } catch(e) {
    body.innerHTML = `<p class="text-danger small text-center py-3">Failed to load tests: ${e.message}</p>`;
    console.error('loadTestHistory error:', e);
  }
}

loadTestHistory();
</script>
</body>
</html>

