<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .dept-card { border-left: 4px solid #d4af37; border-radius: 10px; }
    .dept-card .dept-header { background: linear-gradient(90deg,#fffdf0,#fff); border-radius: 6px 6px 0 0; }
    .user-row { transition: background .15s; }
    .user-row:hover { background: rgba(212,175,55,.06); }
    .admin-card { border-left: 4px solid #dc3545; border-radius: 10px; }
    .admin-card .dept-header { background: linear-gradient(90deg,#fff5f5,#fff); border-radius: 6px 6px 0 0; }
    .badge-dept { font-size: 11px; font-weight: 500; letter-spacing: .3px; }
    .stat-pill { border-radius: 8px; padding: 14px 20px; text-align:center; }
  </style>
</head>
<body class="admin-page">
<div class="admin-wrapper">

  <!-- Sidebar -->
  <nav class="admin-sidebar d-flex flex-column">
    <div class="sidebar-brand">
      <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo" onerror="this.style.display='none'">
      <div>
        <div class="fw-bold text-gold">Patrika HR</div>
        <small class="text-white-50">Admin Panel</small>
      </div>
    </div>
    <hr class="border-secondary my-2">
    <ul class="nav flex-column px-2 flex-grow-1">
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/candidates"><i class="bi bi-people-fill me-2"></i>Candidates</a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/positions"><i class="bi bi-briefcase-fill me-2"></i>Positions</a>
      </li>
      <% } %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/requisitions"><i class="bi bi-clipboard-check-fill me-2"></i>Requisitions</a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/talent-analyst"><i class="bi bi-robot me-2"></i>Talent Analyst</a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/resume-parser"><i class="bi bi-file-earmark-text me-2"></i>Resume Parser</a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/apply" target="_blank"><i class="bi bi-file-earmark-person me-2"></i>Application Form</a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link active" href="/admin/users"><i class="bi bi-person-gear me-2"></i>User Management</a>
      </li>
      <% } %>
    </ul>
    <div class="px-2 pb-3">
      <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
      <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">
        Logged in as <strong><%= adminName %></strong>
        <% if (typeof adminDepartment !== 'undefined' && adminDepartment) { %>
        <span class="badge bg-warning text-dark d-block mt-1"><%= adminDepartment %></span>
        <% } %>
      </p>
    </div>
  </nav>

  <!-- Main -->
  <main class="admin-main">
    <div class="admin-topbar d-flex align-items-center justify-content-between">
      <div>
        <h5 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2 text-gold"></i>User Management</h5>
        <small class="text-muted">Department-wise user accounts</small>
      </div>
      <button class="btn btn-gold btn-sm" onclick="openAddModal('')">
        <i class="bi bi-person-plus me-1"></i>Add User
      </button>
    </div>

    <div class="p-4">

      <%
        const admins    = users.filter(u => u.role === 'admin');
        const deptUsers = users.filter(u => u.role === 'user');

        // department getter returns array; group by each dept the user belongs to
        const byDept = {};
        deptUsers.forEach(u => {
          const dArr = Array.isArray(u.department) ? u.department : (u.department ? [u.department] : []);
          if (dArr.length === 0) {
            if (!byDept['Unassigned']) byDept['Unassigned'] = [];
            byDept['Unassigned'].push(u);
          } else {
            dArr.forEach(d => {
              if (!byDept[d]) byDept[d] = [];
              byDept[d].push(u);
            });
          }
        });

        // departments that have no users yet
        const emptyDepts = allDepts.filter(d => !byDept[d]);
      %>

      <!-- Stats row -->
      <div class="row g-3 mb-4">
        <div class="col-auto">
          <div class="stat-pill bg-white border shadow-sm">
            <div class="fw-bold fs-4 text-gold"><%= users.length %></div>
            <div class="small text-muted">Total Users</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-pill bg-white border shadow-sm">
            <div class="fw-bold fs-4 text-danger"><%= admins.length %></div>
            <div class="small text-muted">Admins</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-pill bg-white border shadow-sm">
            <div class="fw-bold fs-4 text-primary"><%= deptUsers.length %></div>
            <div class="small text-muted">Dept Users</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-pill bg-white border shadow-sm">
            <div class="fw-bold fs-4 text-secondary"><%= allDepts.length %></div>
            <div class="small text-muted">Departments</div>
          </div>
        </div>
      </div>

      <!-- Role info -->
      <div class="alert alert-info d-flex gap-3 align-items-start py-2 mb-4">
        <i class="bi bi-info-circle-fill mt-1 flex-shrink-0"></i>
        <div class="small">
          <strong>Admin</strong> — Full access to all candidates, positions, and settings across all departments.<br>
          <strong>User</strong> — Restricted to selected departments. Can view/manage candidates only for their assigned departments' positions.
        </div>
      </div>

      <!-- ── Admins section ─────────────────────────────────────────────── -->
      <div class="card shadow-sm admin-card mb-4">
        <div class="dept-header d-flex align-items-center justify-content-between px-4 py-3">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-shield-fill-check text-danger fs-5"></i>
            <span class="fw-bold">Super Admins</span>
            <span class="badge bg-danger rounded-pill"><%= admins.length %></span>
          </div>
          <button class="btn btn-sm btn-outline-danger" onclick="openAddModal('', 'admin')">
            <i class="bi bi-person-plus me-1"></i>Add Admin
          </button>
        </div>
        <div class="card-body p-0">
          <% if (admins.length) { %>
          <table class="table table-hover mb-0">
            <thead class="table-light"><tr>
              <th class="ps-4">Name</th><th>Username</th><th>Created</th><th class="text-end pe-4">Actions</th>
            </tr></thead>
            <tbody>
              <% admins.forEach(u => { %>
              <tr class="user-row">
                <td class="ps-4 fw-semibold"><i class="bi bi-person-fill-check text-danger me-2"></i><%= u.name %></td>
                <td><code><%= u.username %></code></td>
                <td class="text-muted small"><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-IN') : '—' %></td>
                <td class="text-end pe-3">
                  <button class="btn btn-sm btn-outline-gold me-1 edit-user-btn"
                    data-id="<%= u.id %>" data-name="<%= u.name %>"
                    data-role="admin" data-depts="[]" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-danger delete-user-btn"
                    data-id="<%= u.id %>" data-name="<%= u.name %>" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } else { %>
          <p class="text-muted text-center py-3 mb-0">No admins found</p>
          <% } %>
        </div>
      </div>

      <!-- ── Department sections ────────────────────────────────────────── -->
      <% Object.entries(byDept).forEach(([dept, dUsers]) => { %>
      <div class="card shadow-sm dept-card mb-3">
        <div class="dept-header d-flex align-items-center justify-content-between px-4 py-3">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-diagram-3-fill text-gold fs-5"></i>
            <span class="fw-bold"><%= dept %></span>
            <span class="badge bg-warning text-dark rounded-pill"><%= dUsers.length %> user<%= dUsers.length !== 1 ? 's' : '' %></span>
          </div>
          <button class="btn btn-sm btn-outline-gold" onclick="openAddModal('<%= dept %>')">
            <i class="bi bi-person-plus me-1"></i>Add to <%= dept %>
          </button>
        </div>
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead class="table-light"><tr>
              <th class="ps-4">Name</th><th>Username</th><th>Departments</th><th>Created</th><th class="text-end pe-4">Actions</th>
            </tr></thead>
            <tbody>
              <% dUsers.forEach(u => { %>
              <% const uDepts = Array.isArray(u.department) ? u.department : (u.department ? [u.department] : []); %>
              <tr class="user-row">
                <td class="ps-4 fw-semibold"><i class="bi bi-person-fill text-primary me-2"></i><%= u.name %></td>
                <td><code><%= u.username %></code></td>
                <td>
                  <% uDepts.forEach(d => { %>
                  <span class="badge bg-warning text-dark me-1"><%= d %></span>
                  <% }) %>
                </td>
                <td class="text-muted small"><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-IN') : '—' %></td>
                <td class="text-end pe-3">
                  <button class="btn btn-sm btn-outline-gold me-1 edit-user-btn"
                    data-id="<%= u.id %>" data-name="<%= u.name %>"
                    data-role="user" data-depts='<%- JSON.stringify(uDepts) %>' title="Edit">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-danger delete-user-btn"
                    data-id="<%= u.id %>" data-name="<%= u.name %>" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% }) %>

      <!-- Departments with no users yet -->
      <% if (emptyDepts.length) { %>
      <div class="card shadow-sm border-dashed mb-3" style="border:2px dashed #ddd;">
        <div class="card-header bg-white">
          <span class="fw-semibold text-muted"><i class="bi bi-inbox me-2"></i>Departments with no users yet</span>
        </div>
        <div class="card-body">
          <div class="d-flex flex-wrap gap-2">
            <% emptyDepts.forEach(d => { %>
            <div class="d-flex align-items-center gap-2 border rounded px-3 py-2 bg-light">
              <span class="badge bg-secondary badge-dept"><%= d %></span>
              <button class="btn btn-xs btn-sm btn-outline-gold py-0 px-2" style="font-size:12px;" onclick="openAddModal('<%= d %>')">
                <i class="bi bi-person-plus me-1"></i>Add User
              </button>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

    </div>
  </main>
</div>

<!-- Add / Edit Modal (shared) -->
<div class="modal fade" id="userModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="modalTitle"><i class="bi bi-person-plus me-2 text-gold"></i>Add User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="modal-id">
        <div class="mb-3">
          <label class="form-label fw-semibold">Full Name *</label>
          <input type="text" class="form-control" id="modal-name" placeholder="e.g. Rajesh Kumar">
        </div>
        <div class="mb-3" id="username-wrapper">
          <label class="form-label fw-semibold">Username *</label>
          <input type="text" class="form-control" id="modal-username" placeholder="e.g. rajesh.kumar">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold" id="password-label">Password *</label>
          <input type="password" class="form-control" id="modal-password" placeholder="Min 8 characters">
          <div class="form-text" id="password-hint" style="display:none;">Leave blank to keep current password</div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Role *</label>
          <select class="form-select" id="modal-role" onchange="toggleDept()">
            <option value="user">User (Department Restricted)</option>
            <option value="admin">Admin (Full Access)</option>
          </select>
        </div>
        <div class="mb-3" id="dept-wrapper">
          <label class="form-label fw-semibold">Departments * <small class="text-muted fw-normal">(select one or more)</small></label>
          <div class="border rounded p-2" style="max-height:200px;overflow-y:auto;" id="dept-checkboxes">
            <% allDepts.forEach(d => { %>
            <div class="form-check">
              <input class="form-check-input dept-cb" type="checkbox" value="<%= d %>" id="cb_<%= d.replace(/\s+/g,'_') %>">
              <label class="form-check-label" for="cb_<%= d.replace(/\s+/g,'_') %>"><%= d %></label>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="saveUserBtn"><i class="bi bi-check-lg me-1"></i>Save</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
let modalMode = 'add';
const bsModal = new bootstrap.Modal(document.getElementById('userModal'));

function toggleDept() {
  const role = document.getElementById('modal-role').value;
  document.getElementById('dept-wrapper').style.display = role === 'user' ? '' : 'none';
}

function setCheckedDepts(depts) {
  document.querySelectorAll('.dept-cb').forEach(cb => {
    cb.checked = depts.includes(cb.value);
  });
}

function getCheckedDepts() {
  return [...document.querySelectorAll('.dept-cb:checked')].map(cb => cb.value);
}

function openAddModal(dept, role) {
  modalMode = 'add';
  document.getElementById('modalTitle').innerHTML = '<i class="bi bi-person-plus me-2 text-gold"></i>Add New User';
  document.getElementById('modal-id').value       = '';
  document.getElementById('modal-name').value     = '';
  document.getElementById('modal-username').value = '';
  document.getElementById('modal-password').value = '';
  document.getElementById('modal-role').value     = role || 'user';
  setCheckedDepts(dept ? [dept] : []);
  document.getElementById('username-wrapper').style.display = '';
  document.getElementById('password-label').textContent     = 'Password *';
  document.getElementById('password-hint').style.display    = 'none';
  toggleDept();
  bsModal.show();
}

// Edit user
document.querySelectorAll('.edit-user-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    modalMode = 'edit';
    document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil me-2 text-gold"></i>Edit User';
    document.getElementById('modal-id').value       = this.dataset.id;
    document.getElementById('modal-name').value     = this.dataset.name;
    document.getElementById('modal-username').value = '';
    document.getElementById('modal-password').value = '';
    document.getElementById('modal-role').value     = this.dataset.role;
    const depts = JSON.parse(this.dataset.depts || '[]');
    setCheckedDepts(depts);
    document.getElementById('username-wrapper').style.display = 'none';
    document.getElementById('password-label').textContent     = 'New Password';
    document.getElementById('password-hint').style.display    = '';
    toggleDept();
    bsModal.show();
  });
});

// Save
document.getElementById('saveUserBtn').addEventListener('click', async function() {
  const name       = document.getElementById('modal-name').value.trim();
  const username   = document.getElementById('modal-username').value.trim();
  const password   = document.getElementById('modal-password').value.trim();
  const role       = document.getElementById('modal-role').value;
  const departments = getCheckedDepts();
  const id         = document.getElementById('modal-id').value;

  if (!name) return alert('Name is required');
  if (modalMode === 'add' && (!username || !password)) return alert('Username and password are required');
  if (role === 'user' && departments.length === 0) return alert('Please select at least one department');

  this.disabled = true;
  try {
    let url = '/admin/users', method = 'POST';
    if (modalMode === 'edit') { url = `/admin/users/${id}`; method = 'PUT'; }

    const body = { name, role, departments: role === 'user' ? departments : [] };
    if (modalMode === 'add') { body.username = username; body.password = password; }
    if (modalMode === 'edit' && password) body.password = password;

    const r = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const d = await r.json();
    if (d.success) { location.reload(); }
    else { alert(d.error || 'Failed'); }
  } catch(e) { alert('Network error: ' + e.message); }
  this.disabled = false;
});

// Delete
document.querySelectorAll('.delete-user-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    if (!confirm(`Delete user "${this.dataset.name}"?`)) return;
    try {
      const r = await fetch(`/admin/users/${this.dataset.id}`, { method: 'DELETE' });
      const d = await r.json();
      if (d.success) { location.reload(); }
      else { alert(d.error || 'Failed to delete'); }
    } catch(e) { alert('Network error: ' + e.message); }
  });
});
</script>
</body>
</html>
