<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
</head>
<body class="admin-page">
<div class="admin-wrapper">

  <!-- Sidebar -->
  <nav class="admin-sidebar d-flex flex-column">
    <div class="sidebar-brand">
      <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo" onerror="this.style.display='none'">
      <div>
        <div class="fw-bold text-gold">Patrika HR</div>
        <small class="text-white-50">Admin Panel</small>
      </div>
    </div>
    <hr class="border-secondary my-2">
    <ul class="nav flex-column px-2 flex-grow-1">
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/dashboard">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/candidates">
          <i class="bi bi-people-fill me-2"></i>Candidates
        </a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/positions">
          <i class="bi bi-briefcase-fill me-2"></i>Positions
        </a>
      </li>
      <% } %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/requisitions">
          <i class="bi bi-clipboard-check-fill me-2"></i>Requisitions
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/talent-analyst">
          <i class="bi bi-robot me-2"></i>Talent Analyst
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/resume-parser">
          <i class="bi bi-file-earmark-text me-2"></i>Resume Parser
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/apply" target="_blank">
          <i class="bi bi-file-earmark-person me-2"></i>Application Form
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link active" href="/admin/users">
          <i class="bi bi-person-gear me-2"></i>User Management
        </a>
      </li>
    </ul>
    <div class="px-2 pb-3">
      <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
      </a>
      <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">
        Logged in as <strong><%= adminName %></strong>
      </p>
    </div>
  </nav>

  <!-- Main -->
  <main class="admin-main">
    <div class="admin-topbar d-flex align-items-center justify-content-between">
      <div>
        <h5 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2 text-gold"></i>User Management</h5>
        <small class="text-muted">Manage admin and department-level user accounts</small>
      </div>
      <button class="btn btn-gold btn-sm" data-bs-toggle="modal" data-bs-target="#addUserModal">
        <i class="bi bi-person-plus me-1"></i>Add User
      </button>
    </div>

    <div class="p-4">

      <!-- Role legend -->
      <div class="alert alert-info d-flex gap-3 align-items-start py-2 mb-4">
        <i class="bi bi-info-circle-fill mt-1"></i>
        <div class="small">
          <strong>Admin</strong> — Full access to all candidates, positions, and settings across all departments.<br>
          <strong>User</strong> — Restricted to one department. Can view/manage candidates only for their department's positions.
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Username</th>
                  <th>Role</th>
                  <th>Department</th>
                  <th>Created</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((u, i) => { %>
                <tr>
                  <td class="text-muted"><%= i + 1 %></td>
                  <td class="fw-semibold"><%= u.name %></td>
                  <td><code><%= u.username %></code></td>
                  <td>
                    <% if (u.role === 'admin') { %>
                    <span class="badge bg-danger">Admin</span>
                    <% } else { %>
                    <span class="badge bg-primary">User</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (u.department) { %>
                    <span class="badge bg-warning text-dark"><%= u.department %></span>
                    <% } else { %>
                    <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td class="text-muted small"><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-IN') : '—' %></td>
                  <td class="text-end pe-3">
                    <button class="btn btn-sm btn-outline-gold edit-user-btn me-1"
                      data-id="<%= u.id %>"
                      data-name="<%= u.name %>"
                      data-role="<%= u.role %>"
                      data-dept="<%= u.department || '' %>"
                      title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger delete-user-btn"
                      data-id="<%= u.id %>"
                      data-name="<%= u.name %>"
                      title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
                <% }) %>
                <% if (!users.length) { %>
                <tr><td colspan="7" class="text-center text-muted py-4">No users found</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-person-plus me-2 text-gold"></i>Add New User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-semibold">Full Name *</label>
          <input type="text" class="form-control" id="add-name" placeholder="e.g. Rajesh Kumar">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Username *</label>
          <input type="text" class="form-control" id="add-username" placeholder="e.g. rajesh.kumar">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Password *</label>
          <input type="password" class="form-control" id="add-password" placeholder="Min 8 characters">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Role *</label>
          <select class="form-select" id="add-role" onchange="toggleDeptField('add')">
            <option value="user">User (Department Restricted)</option>
            <option value="admin">Admin (Full Access)</option>
          </select>
        </div>
        <div class="mb-3" id="add-dept-wrapper">
          <label class="form-label fw-semibold">Department *</label>
          <select class="form-select" id="add-dept">
            <option value="">— Select Department —</option>
            <% allDepts.forEach(d => { %>
            <option value="<%= d %>"><%= d %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="addUserBtn"><i class="bi bi-check-lg me-1"></i>Create User</button>
      </div>
    </div>
  </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-gold"></i>Edit User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="edit-id">
        <div class="mb-3">
          <label class="form-label fw-semibold">Full Name *</label>
          <input type="text" class="form-control" id="edit-name">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">New Password <small class="text-muted">(leave blank to keep current)</small></label>
          <input type="password" class="form-control" id="edit-password" placeholder="Leave blank to keep unchanged">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Role *</label>
          <select class="form-select" id="edit-role" onchange="toggleDeptField('edit')">
            <option value="user">User (Department Restricted)</option>
            <option value="admin">Admin (Full Access)</option>
          </select>
        </div>
        <div class="mb-3" id="edit-dept-wrapper">
          <label class="form-label fw-semibold">Department *</label>
          <select class="form-select" id="edit-dept">
            <option value="">— Select Department —</option>
            <% allDepts.forEach(d => { %>
            <option value="<%= d %>"><%= d %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="editUserBtn"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function toggleDeptField(prefix) {
  const role = document.getElementById(prefix + '-role').value;
  document.getElementById(prefix + '-dept-wrapper').style.display = role === 'user' ? '' : 'none';
}
toggleDeptField('add');

// Add User
document.getElementById('addUserBtn').addEventListener('click', async function() {
  const name = document.getElementById('add-name').value.trim();
  const username = document.getElementById('add-username').value.trim();
  const password = document.getElementById('add-password').value.trim();
  const role = document.getElementById('add-role').value;
  const department = document.getElementById('add-dept').value;
  if (!name || !username || !password) return alert('Name, username and password are required');
  if (role === 'user' && !department) return alert('Please select a department for this user');
  this.disabled = true;
  try {
    const r = await fetch('/admin/users', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, username, password, role, department })
    });
    const d = await r.json();
    if (d.success) { location.reload(); }
    else { alert(d.error || 'Failed to create user'); }
  } catch(e) { alert('Network error: ' + e.message); }
  this.disabled = false;
});

// Edit User — open modal
document.querySelectorAll('.edit-user-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.getElementById('edit-id').value   = this.dataset.id;
    document.getElementById('edit-name').value = this.dataset.name;
    document.getElementById('edit-role').value = this.dataset.role;
    document.getElementById('edit-dept').value = this.dataset.dept;
    document.getElementById('edit-password').value = '';
    toggleDeptField('edit');
    new bootstrap.Modal(document.getElementById('editUserModal')).show();
  });
});

document.getElementById('editUserBtn').addEventListener('click', async function() {
  const id   = document.getElementById('edit-id').value;
  const name = document.getElementById('edit-name').value.trim();
  const role = document.getElementById('edit-role').value;
  const department = document.getElementById('edit-dept').value;
  const password = document.getElementById('edit-password').value.trim();
  if (!name) return alert('Name is required');
  if (role === 'user' && !department) return alert('Please select a department');
  this.disabled = true;
  try {
    const r = await fetch(`/admin/users/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, role, department, password: password || undefined })
    });
    const d = await r.json();
    if (d.success) { location.reload(); }
    else { alert(d.error || 'Failed to update'); }
  } catch(e) { alert('Network error: ' + e.message); }
  this.disabled = false;
});

// Delete User
document.querySelectorAll('.delete-user-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    if (!confirm(`Delete user "${this.dataset.name}"?`)) return;
    try {
      const r = await fetch(`/admin/users/${this.dataset.id}`, { method: 'DELETE' });
      const d = await r.json();
      if (d.success) { location.reload(); }
      else { alert(d.error || 'Failed to delete'); }
    } catch(e) { alert('Network error: ' + e.message); }
  });
});
</script>
</body>
</html>
