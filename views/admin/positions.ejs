document.getElementById('deleteConfirmBtn').addEventListener('click', async function() {
  if (!deleteId) return;
  this.disabled = true;
  try {
    const r = await fetch(`/admin/positions/${deleteId}`, { method: 'DELETE' });
    const d = await r.json();
    if (d.success) {
      bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
      document.querySelector(`tr[data-id="${deleteId}"]`).remove();
      updateCounts();
    } else { alert(d.error || 'Failed to delete'); }
  } catch(e) { alert('Network error'); }
  this.disabled = false;
  deleteId = null;
});

// ── JD File Upload ───────────────────────────────────────────
function handleJdFile(input, mode) {
  const file = input.files[0];
  if (!file) return;
  const q = mode === 'add' ? addQuill : editQuill;
  const reader = new FileReader();
  reader.onload = function(e) {
    const content = e.target.result;
    const isHtml = /<[a-z][\s\S]*>/i.test(content);
    if (isHtml) {
      q.clipboard.dangerouslyPasteHTML(content);
    } else {
      q.setText(content);
    }
    input.value = '';
  };
  reader.readAsText(file);
}

// ── Department Management ────────────────────────────────────
// Keep a client-side map of name→id so we can delete by name
const deptMap = {};
<%  if (typeof departments !== 'undefined') { %>
// We'll fetch IDs from server on delete; no need to embed IDs in HTML
<% } %>

async function addDepartment() {
  const input = document.getElementById('newDeptName');
  const name = input.value.trim();
  if (!name) return alert('Enter a department name');
  try {
    const r = await fetch('/admin/departments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    const d = await r.json();
    if (!d.success) return alert(d.error || 'Failed to add department');
    // Add badge to UI
    const container = document.getElementById('deptTagsContainer');
    container.querySelectorAll('.text-muted').forEach(el => el.remove());
    const badge = document.createElement('span');
    badge.className = 'badge bg-warning text-dark d-flex align-items-center gap-1 px-2 py-2 dept-tag';
    badge.dataset.name = name;
    badge.dataset.id   = d.department.id;
    badge.style.fontSize = '13px';
    badge.innerHTML = `${name} <button type="button" class="btn-close btn-close-dark ms-1" style="font-size:9px;" onclick="deleteDepartmentByName('${name.replace(/'/g,"\\'")}', ${d.department.id})" title="Remove"></button>`;
    container.appendChild(badge);
    // Add to both dropdowns
    ['add-dept','edit-dept'].forEach(id => {
      const sel = document.getElementById(id);
      if (sel) {
        const opt = document.createElement('option');
        opt.text = name; opt.value = name;
        sel.appendChild(opt);
      }
    });
    input.value = '';
  } catch(e) { alert('Network error: ' + e.message); }
}

async function deleteDepartmentByName(name, knownId) {
  if (!confirm(`Remove department "${name}"?\nExisting positions will keep this department but it won't appear in the dropdown.`)) return;
  try {
    let id = knownId;
    if (!id) {
      // fetch ID from server if not known
      const r = await fetch('/admin/departments');
      // fallback: just reload
      location.reload(); return;
    }
    const r = await fetch(`/admin/departments/${id}`, { method: 'DELETE' });
    const d = await r.json();
    if (!d.success) return alert(d.error || 'Failed to delete');
    // Remove badge
    document.querySelectorAll(`.dept-tag`).forEach(el => {
      if (el.dataset.name === name) el.remove();
    });
    if (!document.querySelector('.dept-tag')) {
      document.getElementById('deptTagsContainer').innerHTML = '<span class="text-muted small">No departments yet. Add one above.</span>';
    }
    // Remove from dropdowns
    ['add-dept','edit-dept'].forEach(selId => {
      const sel = document.getElementById(selId);
      if (sel) Array.from(sel.options).forEach(o => { if (o.value === name) sel.remove(o.index); });
    });
  } catch(e) { alert('Network error: ' + e.message); }
}

document.getElementById('newDeptName').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') { e.preventDefault(); addDepartment(); }
});
