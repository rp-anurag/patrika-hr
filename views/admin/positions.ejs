<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
  <link href="/css/style.css?v=<%= v %>" rel="stylesheet">
  <style>
    .pos-row td { vertical-align: middle; }
    .badge-pill { font-size: 11px; font-weight: 500; }
    .jd-preview { font-size: 12px; color: #666; max-height: 40px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300px; }
    .form-switch .form-check-input { width: 2.5em; cursor: pointer; }
    .icon-preview { font-size: 1.1rem; }
    .drag-handle { cursor: grab; color: #aaa; }
    .inactive-row { opacity: 0.55; }
    .ql-container { font-size: 14px; }
    .ql-toolbar.ql-snow { border-radius: 6px 6px 0 0; background: #f8f9fa; }
    .ql-container.ql-snow { border-radius: 0 0 6px 6px; }
  </style>
</head>
<body class="admin-page">
<div class="admin-wrapper">

  <!-- Sidebar -->
  <nav class="admin-sidebar d-flex flex-column">
    <div class="sidebar-brand">
      <img src="/images/patrika-logo.png" alt="Patrika" class="sidebar-logo" onerror="this.style.display='none'">
      <div>
        <div class="fw-bold text-gold">Patrika HR</div>
        <small class="text-white-50">Admin Panel</small>
      </div>
    </div>
    <hr class="border-secondary my-2">
    <ul class="nav flex-column px-2 flex-grow-1">
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/dashboard">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/candidates">
            <i class="bi bi-people-fill me-2"></i>Candidates
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/newstech" style="padding-left:2rem;font-size:.85rem;">
            <i class="bi bi-newspaper me-2"></i>News-Tech Lab
          </a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link active" href="/admin/positions">
          <i class="bi bi-briefcase-fill me-2"></i>Positions
        </a>
      </li>
      <% } %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/requisitions">
          <i class="bi bi-clipboard-check-fill me-2"></i>Requisitions
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/talent-analyst"><i class="bi bi-robot me-2"></i>Talent Analyst</a>
        </li>
        <li class="nav-item">
          <a class="nav-link sidebar-link" href="/admin/resume-parser">
          <i class="bi bi-file-earmark-text me-2"></i>Resume Parser
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/apply" target="_blank">
          <i class="bi bi-file-earmark-person me-2"></i>Application Form
        </a>
      </li>
      <% if (typeof adminRole === 'undefined' || adminRole === 'admin') { %>
      <li class="nav-item">
        <a class="nav-link sidebar-link" href="/admin/users">
          <i class="bi bi-person-gear me-2"></i>User Management
        </a>
      </li>
      <% } %>
    </ul>
    <div class="px-2 pb-3">
      <a href="/admin/logout" class="btn btn-outline-light btn-sm w-100">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
      </a>
      <p class="text-white-50 text-center mt-2 mb-0" style="font-size:11px;">
        Logged in as <strong><%= adminName %></strong>
        <% if (typeof adminDepartment !== 'undefined' && adminDepartment) { %>
        <span class="badge bg-warning text-dark d-block mt-1"><%= adminDepartment %></span>
        <% } %>
      </p>
    </div>
  </nav>

  <!-- Main -->
  <main class="admin-main">
    <div class="admin-topbar d-flex align-items-center justify-content-between">
      <div>
        <h5 class="mb-0 fw-bold">Positions & Job Descriptions</h5>
        <small class="text-muted">Manage open positions shown on the apply form</small>
      </div>
      <button class="btn btn-gold btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Position
      </button>
    </div>

    <div class="p-4">

      <!-- Manage Departments -->
      <div class="card shadow-sm mb-4">
        <div class="card-header d-flex align-items-center justify-content-between py-2">
          <span class="fw-semibold"><i class="bi bi-diagram-3 me-2 text-gold"></i>Manage Departments</span>
          <div class="d-flex gap-2 align-items-center">
            <input type="text" class="form-control form-control-sm" id="newDeptName" placeholder="New department name" style="width:220px;">
            <button class="btn btn-gold btn-sm" onclick="addDepartment()"><i class="bi bi-plus-lg me-1"></i>Add</button>
          </div>
        </div>
        <div class="card-body py-2">
          <div class="d-flex flex-wrap gap-2" id="deptTagsContainer">
            <% if (typeof departmentObjs !== 'undefined' && departmentObjs.length > 0) { departmentObjs.forEach(function(d) { %>
            <span class="badge bg-warning text-dark d-flex align-items-center gap-1 px-2 py-2 dept-tag" data-name="<%= d.name %>" data-id="<%= d.id %>" style="font-size:13px;">
              <%= d.name %>
              <button type="button" class="btn-close btn-close-dark ms-1" style="font-size:9px;" onclick="deleteDepartmentByName('<%= d.name.replace(/'/g, '\\&#39;') %>', <%= d.id %>)" title="Remove"></button>
            </span>
            <% }) } else { %>
            <span class="text-muted small">No departments yet. Add one above.</span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="row g-3 mb-4">
        <div class="col-auto">
          <div class="stat-card stat-card-gold px-4 py-3" style="border-radius:10px;">
            <div class="stat-value" id="totalCount"><%= positions.length %></div>
            <div class="stat-label">Total Positions</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-card px-4 py-3 bg-white border" style="border-radius:10px;">
            <div class="stat-value text-success" id="activeCount"><%= positions.filter(p=>p.isActive).length %></div>
            <div class="stat-label text-muted">Active</div>
          </div>
        </div>
        <div class="col-auto">
          <div class="stat-card px-4 py-3 bg-white border" style="border-radius:10px;">
            <div class="stat-value text-secondary" id="inactiveCount"><%= positions.filter(p=>!p.isActive).length %></div>
            <div class="stat-label text-muted">Inactive</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="card shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="posTable">
              <thead class="table-light">
                <tr>
                  <th style="width:32px"></th>
                  <th>Position</th>
                  <th>Department</th>
                  <th>Badge</th>
                  <th>Job Description</th>
                  <th class="text-center">Active</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody id="posTableBody">
                <% positions.forEach(pos => { %>
                <tr class="pos-row <%= pos.isActive ? '' : 'inactive-row' %>" data-id="<%= pos.id %>">
                  <td class="drag-handle ps-3"><i class="bi bi-grip-vertical"></i></td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <i class="bi bi-<%= pos.icon %> icon-preview text-gold"></i>
                      <div>
                        <div class="fw-semibold"><%= pos.name %></div>
                        <small class="text-muted">Sort: <%= pos.sortOrder %></small>
                      </div>
                    </div>
                  </td>
                  <td><span class=”badge bg-light text-dark border badge-pill”><%= pos.department || '—' %></span></td>
                  <td><small class=”text-muted”><%= pos.badge || '—' %></small></td>
                  <td>
                    <% if (pos.jdHtml && pos.jdHtml.trim()) { %>
                      <div class="jd-preview"><%- pos.jdHtml.replace(/<[^>]+>/g,'').substring(0,120) %>…</div>
                    <% } else { %>
                      <span class="text-danger small"><i class="bi bi-exclamation-circle me-1"></i>No JD</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <div class="form-check form-switch d-flex justify-content-center mb-0">
                      <input class="form-check-input toggle-active" type="checkbox"
                        data-id="<%= pos.id %>" <%= pos.isActive ? 'checked' : '' %>>
                    </div>
                  </td>
                  <td class="text-end pe-3">
                    <button class="btn btn-sm btn-outline-gold edit-btn me-1"
                      data-id="<%= pos.id %>"
                      data-name="<%= pos.name %>"
                      data-dept="<%= pos.department %>"
                      data-icon="<%= pos.icon %>"
                      data-badge="<%= pos.badge %>"
                      data-sort="<%= pos.sortOrder %>"
                      data-jd="<%= encodeURIComponent(pos.jdHtml || '') %>"
                      title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger delete-btn"
                      data-id="<%= pos.id %>" data-name="<%= pos.name %>" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>Only <strong>Active</strong> positions appear on the candidate apply form.</p>
    </div>
  </main>
</div>

<!-- â”€â”€ Add Position Modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
<div class="modal fade" id="addModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-gold"></i>Add New Position</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Position Name *</label>
            <input type="text" class="form-control" id="add-name" placeholder="e.g. Sales Head Delhi">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Department</label>
            <select class="form-select" id="add-dept">
              <option value="">— Select Department —</option>
              <% (typeof departments !== 'undefined' ? departments : []).forEach(d => { %>
              <option><%= d %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold">Sort Order</label>
            <input type="number" class="form-control" id="add-sort" value="0" min="0">
          </div>
          <div class="col-md-1">
            <label class="form-label fw-semibold">Icon</label>
            <input type="text" class="form-control" id="add-icon" value="briefcase" placeholder="briefcase">
            <small class="text-muted">Bootstrap icon name</small>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Badge Text</label>
            <input type="text" class="form-control" id="add-badge" placeholder="e.g. Jaipur · Full-Time · 5+ Yrs">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Job Description</label>
            <div class="d-flex gap-2 mb-2">
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertJdTemplate('add')"><i class="bi bi-layout-text-window me-1"></i>Insert Template</button>
              <label class="btn btn-sm btn-outline-secondary mb-0">
                <i class="bi bi-upload me-1"></i>Upload File
                <input type="file" id="add-jd-file" accept=".txt,.html,.htm" class="d-none" onchange="handleJdFile(this,'add')">
              </label>
            </div>
            <div id="add-jd-editor" style="height:280px;"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="addSaveBtn"><i class="bi bi-check-lg me-1"></i>Add Position</button>
      </div>
    </div>
  </div>
</div>

<!-- â”€â”€ Edit Position Modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-gold"></i>Edit Position</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="edit-id">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Position Name *</label>
            <input type="text" class="form-control" id="edit-name">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Department</label>
            <select class="form-select" id="edit-dept">
              <option value="">— Select Department —</option>
              <% (typeof departments !== 'undefined' ? departments : []).forEach(d => { %>
              <option><%= d %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold">Sort Order</label>
            <input type="number" class="form-control" id="edit-sort" min="0">
          </div>
          <div class="col-md-1">
            <label class="form-label fw-semibold">Icon</label>
            <input type="text" class="form-control" id="edit-icon">
            <small class="text-muted">Bootstrap icon name</small>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Badge Text</label>
            <input type="text" class="form-control" id="edit-badge">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Job Description</label>
            <div class="d-flex gap-2 mb-2">
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertJdTemplate('edit')"><i class="bi bi-layout-text-window me-1"></i>Insert Template</button>
              <label class="btn btn-sm btn-outline-secondary mb-0">
                <i class="bi bi-upload me-1"></i>Upload File
                <input type="file" id="edit-jd-file" accept=".txt,.html,.htm" class="d-none" onchange="handleJdFile(this,'edit')">
              </label>
            </div>
            <div id="edit-jd-editor" style="height:280px;"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-gold" id="editSaveBtn"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- â”€â”€ Delete Confirm Modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete Position</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete <strong id="delete-name"></strong>? This cannot be undone.
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" id="deleteConfirmBtn">Delete</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
// ── Quill rich text editors ──────────────────────────────────
const quillToolbar = [
  [{ header: [1, 2, 3, false] }],
  ['bold', 'italic', 'underline', 'strike'],
  [{ color: [] }, { background: [] }],
  [{ list: 'ordered' }, { list: 'bullet' }],
  [{ indent: '-1' }, { indent: '+1' }],
  ['link'],
  ['clean']
];

const addQuill  = new Quill('#add-jd-editor',  { theme: 'snow', modules: { toolbar: quillToolbar } });
const editQuill = new Quill('#edit-jd-editor', { theme: 'snow', modules: { toolbar: quillToolbar } });

document.getElementById('addModal').addEventListener('hidden.bs.modal', () => addQuill.setText(''));
document.getElementById('editModal').addEventListener('hidden.bs.modal', () => editQuill.setText(''));

const JD_TEMPLATE = `<h3>Role Overview</h3><p>Brief description of the role...</p><h3>Key Responsibilities</h3><ul><li>Responsibility one</li><li>Responsibility two</li></ul><h3>Requirements</h3><ul><li>Requirement one</li><li>Requirement two</li></ul>`;

function insertJdTemplate(mode) {
  const q = mode === 'add' ? addQuill : editQuill;
  if (!q.getText().trim()) q.clipboard.dangerouslyPasteHTML(JD_TEMPLATE);
}


// â”€â”€ Toggle active â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
document.querySelectorAll('.toggle-active').forEach(el => {
  el.addEventListener('change', async function() {
    const id = this.dataset.id;
    const row = document.querySelector(`tr[data-id="${id}"]`);
    try {
      const r = await fetch(`/admin/positions/${id}/toggle`, { method: 'POST' });
      const d = await r.json();
      if (d.success) {
        row.classList.toggle('inactive-row', !d.isActive);
        updateCounts();
      } else {
        this.checked = !this.checked;
        alert(d.error || 'Failed to toggle');
      }
    } catch(e) { this.checked = !this.checked; alert('Network error'); }
  });
});

function updateCounts() {
  const checks = document.querySelectorAll('.toggle-active');
  const active = [...checks].filter(c => c.checked).length;
  document.getElementById('activeCount').textContent = active;
  document.getElementById('inactiveCount').textContent = checks.length - active;
  document.getElementById('totalCount').textContent = checks.length;
}

// â”€â”€ Edit â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
document.querySelectorAll('.edit-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.getElementById('edit-id').value    = this.dataset.id;
    document.getElementById('edit-name').value  = this.dataset.name;
    document.getElementById('edit-dept').value  = this.dataset.dept;
    document.getElementById('edit-icon').value  = this.dataset.icon;
    document.getElementById('edit-badge').value = this.dataset.badge;
    document.getElementById('edit-sort').value  = this.dataset.sort;
    const jdContent = decodeURIComponent(this.dataset.jd || '');
    editQuill.clipboard.dangerouslyPasteHTML(jdContent);
    new bootstrap.Modal(document.getElementById('editModal')).show();
  });
});

document.getElementById('editSaveBtn').addEventListener('click', async function() {
  const id   = document.getElementById('edit-id').value;
  const body = {
    name:       document.getElementById('edit-name').value.trim(),
    department: document.getElementById('edit-dept').value.trim(),
    icon:       document.getElementById('edit-icon').value.trim() || 'briefcase',
    badge:      document.getElementById('edit-badge').value.trim(),
    jdHtml:     editQuill.root.innerHTML,
    sortOrder:  document.getElementById('edit-sort').value
  };
  if (!body.name) return alert('Position name is required');
  this.disabled = true;
  try {
    const r = await fetch(`/admin/positions/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (d.success) {
      bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
      location.reload();
    } else { alert(d.error || 'Failed to save'); }
  } catch(e) { alert('Network error'); }
  this.disabled = false;
});

// â”€â”€ Add â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
document.getElementById('addSaveBtn').addEventListener('click', async function() {
  const body = {
    name:       document.getElementById('add-name').value.trim(),
    department: document.getElementById('add-dept').value.trim(),
    icon:       document.getElementById('add-icon').value.trim() || 'briefcase',
    badge:      document.getElementById('add-badge').value.trim(),
    jdHtml:     addQuill.root.innerHTML,
    sortOrder:  document.getElementById('add-sort').value
  };
  if (!body.name) return alert('Position name is required');
  this.disabled = true;
  try {
    const r = await fetch('/admin/positions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const d = await r.json();
    if (d.success) {
      bootstrap.Modal.getInstance(document.getElementById('addModal')).hide();
      location.reload();
    } else { alert(d.error || 'Failed to add'); }
  } catch(e) { alert('Network error'); }
  this.disabled = false;
});

